rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Global helper functions
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    // Validation for User Profile
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'displayName', 'photoURL', 'lastLoginAt'])
        && data.keys().size() == 5
        && data.uid is string && data.uid.size() <= 128
        && data.email is string && data.email.size() <= 256
        && (data.displayName == null || (data.displayName is string && data.displayName.size() <= 128))
        && (data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 512))
        && data.lastLoginAt is string && data.lastLoginAt.size() <= 64;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create, update: if isOwner(userId) && isValidUser(incoming()) && incoming().uid == userId;
    }

    // Validation for UserStats
    function isValidUserStats(data) {
      return data.keys().hasAll(['streak', 'lastCompletedDate', 'totalCompleted', 'totalTasks', 'history'])
        && data.keys().size() == 5
        && data.streak is int && data.streak >= 0 && data.streak <= 10000
        && (data.lastCompletedDate == null || (data.lastCompletedDate is string && data.lastCompletedDate.size() <= 32))
        && data.totalCompleted is int && data.totalCompleted >= 0
        && data.totalTasks is int && data.totalTasks >= 0
        && data.history is list && data.history.size() <= 30;
    }

    match /user_stats/{userId} {
      allow get: if isOwner(userId);
      allow create, update: if isOwner(userId) && isValidUserStats(incoming());
    }

    // Validation for Task
    function isValidTask(data) {
      return data.keys().hasAll(['id', 'title', 'description', 'deadline', 'priority', 'category', 'impact', 'dependencies', 'status', 'completedAt', 'createdAt', 'userId', 'urgencyScore'])
        && data.keys().size() == 13
        && data.id is string && data.id.size() <= 128
        && data.title is string && data.title.size() >= 1 && data.title.size() <= 200
        && (data.description == null || (data.description is string && data.description.size() <= 2000))
        && (data.deadline == null || (data.deadline is string && data.deadline.size() <= 64))
        && data.priority is string && (data.priority == 'low' || data.priority == 'medium' || data.priority == 'high')
        && (data.category == null || (data.category is string && data.category.size() <= 100))
        && data.impact is int && data.impact >= 1 && data.impact <= 5
        && data.dependencies is list && data.dependencies.size() <= 50
        && data.status is string && (data.status == 'todo' || data.status == 'doing' || data.status == 'done')
        && (data.completedAt == null || (data.completedAt is string && data.completedAt.size() <= 64))
        && data.createdAt is string && data.createdAt.size() <= 64
        && data.userId is string && data.userId.size() <= 128
        && (data.urgencyScore is number || data.urgencyScore is int);
    }

    match /tasks/{taskId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() 
        && isValidTask(incoming()) 
        && incoming().userId == request.auth.uid
        && incoming().id == taskId;
      allow update: if isSignedIn()
        && isValidTask(incoming())
        && existing().userId == request.auth.uid
        && incoming().userId == request.auth.uid
        && incoming().id == taskId;
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }
  }
}
